default_platform(:ios)

platform :ios do
  desc "Build the iOS IPA for production distribution"
  lane :build_release_ipa do
    app_env = ENV.fetch("APP_ENV", "production")
    build_number = ENV.fetch("IOS_BUILD_NUMBER")
    version_name = ENV.fetch("IOS_VERSION_NAME")
    export_method = ENV.fetch("IOS_EXPORT_METHOD", "app-store")

    sh(
      "fvm",
      "flutter",
      "build",
      "ipa",
      "--release",
      "--build-name=#{version_name}",
      "--build-number=#{build_number}",
      "--dart-define=APP_ENV=#{app_env}",
      "--export-method=#{export_method}"
    )
  end

  desc "Build the iOS app and upload it to TestFlight without submitting for review"
  lane :upload_testflight do
    app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: ENV.fetch("APP_STORE_CONNECT_API_KEY"),
      is_key_content_base64: false,
      in_house: false
    )

    build_release_ipa

    upload_to_testflight(
      ipa: "build/ios/ipa/Runner.ipa",
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      notify_external_testers: false,
      changelog: ENV["TESTFLIGHT_CHANGELOG"]
    )
  end
end
